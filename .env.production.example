# =============================================================================
# PRODUCTION env overlay — DealScope (dealscope.io)
# =============================================================================
# Production runs as a SEPARATE compose project on the same host as staging,
# from a separate checkout (e.g. /home/admin/dealscope on branch `main`).
#
# Setup:
#   1. cp .env.example .env.production          # full var list / structure
#   2. Apply the per-env infra values below.
#   3. ROTATE every secret — production must NOT reuse any staging/dev value.
#   4. Swap every third-party integration to its PRODUCTION/LIVE app + keys.
#   5. chmod 600 .env.production   (gitignored — never commit)
#
# ---- Per-environment infra (isolates prod from staging) ----
PROJECT_NAME=dealscope-prod         # → containers/volumes: dealscope-prod_*
CONTAINER_PREFIX=dsp                # → dsp-api, dsp-db, dsp-redis, dsp-proxy, dsp-capture
PROXY_BIND=127.0.0.1:8091           # host nginx routes dealscope.io → here (8090 = staging)
APP_BASE_URL=https://dealscope.io
# Separate data + identity from staging:
POSTGRES_DB=dealscope
POSTGRES_USER=dealscope_user
DATABASE_APP_USER=dealscope_app
# When using ops/backup-db.sh against prod, set:
#   DB_CONTAINER=dsp-db  API_CONTAINER=dsp-api
#
# ---- ROTATE THESE (generate fresh; do not copy staging) ----
#   POSTGRES_PASSWORD          openssl rand -base64 24
#   DATABASE_APP_PASSWORD      openssl rand -base64 24
#   REDIS_PASSWORD             openssl rand -base64 24
#   JWT_SECRET                 openssl rand -hex 32
#   ENCRYPTION_KEY             openssl rand -base64 32   (secretbox — 32 bytes)
#   ADMIN_PASSWORD             a strong unique value
#
# ---- Swap to PRODUCTION / LIVE third-party apps (not the dev/test ones) ----
#   Google OAuth      new prod client → redirect https://dealscope.io/api/integrations/google/callback
#   Microsoft Graph   new prod Azure app → redirect https://dealscope.io/api/integrations/microsoft/callback
#   Calendly          new prod app → redirect https://dealscope.io/api/integrations/calendly/callback
#   Stripe            LIVE secret/publishable/webhook + LIVE price ids (STRIPE_PRICE_STARTER/PRO)
#   Recall.ai         prod key + webhook https://dealscope.io/webhooks/recall
#   Gemini            prod key (billing-enabled)
#   Apollo / Firecrawl / Brave / Phyllo   prod keys as applicable
#
# ---- SHARED with staging (reuse the SAME staging values — do NOT regenerate) ----
#   SendGrid          SENDGRID_API_KEY + SENDGRID_FROM_EMAIL identical to staging.
#                     EMAIL_SUBJECT_TAG=   (EMPTY in prod — staging carries the "(staging)" tag).
#   Cloudflare        R2 keys (R2_ACCOUNT_ID / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY /
#                     R2_ENDPOINT), CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID, and
#                     CLOUDFLARE_STREAM_* are the same account → reuse staging's.
# ---- NEW Cloudflare resource (same account, isolated data) ----
#   R2_BUCKET=dealscope-prod                    (create the bucket in the dashboard)
#   R2_PUBLIC_BASE_URL=                          (the new bucket's public r2.dev / custom-domain URL)
EMAIL_SUBJECT_TAG=
R2_BUCKET=dealscope-prod
#
# RLS stays on in production:
RLS_ENFORCE=on

# ---------- Public app URL (used in webhooks / emails / SOW links) ----------
APP_BASE_URL=https://ghoststream.exact-it.net

# ---------- Postgres ----------
POSTGRES_DB=ghoststream
POSTGRES_USER=ghoststream_user
POSTGRES_PASSWORD=change-me

# ---------- Redis ----------
REDIS_PASSWORD=change-me

# ---------- Auth ----------
JWT_SECRET=change-me-32-byte-hex
ADMIN_EMAIL=admin@ghoststream.io
ADMIN_PASSWORD=change-me
# Encrypts third-party OAuth/API tokens at rest (secretbox.js). Any high-entropy
# string; generate with: openssl rand -base64 32. If unset, tokens are stored
# UNENCRYPTED (a startup warning is logged). Rotating this key strands existing
# encrypted values — re-auth the affected integrations after a change.
ENCRYPTION_KEY=change-me-run-openssl-rand-base64-32

# ---------- AI engine (Google Gemini — Vertex AI or AI Studio) ----------
GEMINI_API_KEY=
# Default: gemini-2.5-flash (fast, cheap, 1,024-token cache minimum).
GEMINI_MODEL=gemini-2.5-flash
# Per sprint plan: Pro for video analysis (find Moment-of-Truth), Flash-Lite
# for content drafting (SOW / email / portal copy). Swap to gemini-3.1-* once GA.
GEMINI_ANALYSIS_MODEL=gemini-2.5-pro
GEMINI_CONTENT_MODEL=gemini-2.5-flash
# Knowledge Base — Dynamic Context Layer (pgvector RAG).
# gemini-embedding-2 is a Matryoshka-rep model (GA May 2026). 8,192-token
# input window — accommodates long technical manuals without splitting
# coherent sections. We request 768-dim output to match the vector(768)
# column in api/db/migrations/0001_kb_tables.sql. Supported alternates: 1536,
# 3072 — if you change GEMINI_EMBEDDING_DIM, update the vector(N) column AND
# re-embed every chunk (the HNSW index is dim-locked, and switching embedding
# models also requires a full re-embed since vector spaces are incompatible).
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIM=768

# ---------- Omni-Sync providers (WEB + SOCIAL ingestion) ----------
# Firecrawl — drives POST /api/knowledge/web-sync and supplies the scrape /
# map / search calls used by Intel research dossiers.
FIRECRAWL_API_KEY=
# Optional override; defaults to https://api.firecrawl.dev/v1
FIRECRAWL_BASE_URL=

# Brave Search — discovery layer for prospect Deep Research. When set, the
# research pipeline uses Brave /web/search for URL discovery (cheaper, fresher)
# and falls back to Firecrawl /search if unset. Page-body scraping still goes
# through Firecrawl regardless.
BRAVE_API_KEY=
# Optional override; defaults to https://api.search.brave.com/res/v1
BRAVE_BASE_URL=

# NewsAPI — dedicated news source for Deep Research. When set, the research
# pipeline pulls recent news articles for the prospect (last 30 days,
# language=en, sorted by relevancy) and adds them as numbered sources
# alongside Brave/Firecrawl web search. Free tier on newsapi.org gives 100
# req/day which is plenty for prospect research.
NEWSAPI_KEY=
# Optional override — defaults to https://newsapi.org/v2
NEWSAPI_BASE_URL=

# Apollo.io — B2B company + contact enrichment. When set, Deep Research adds
# two extra source blocks per prospect (company snapshot + leadership team)
# and the Prospects/Teams contact pickers autofill name/role from Apollo.
# Requires at least the Basic plan ($49/seat/mo) — the Free plan does NOT
# include REST API access. Get a key at apollo.io → Settings → Integrations
# → API → Create new API Key.
APOLLO_API_KEY=
# Optional override — defaults to https://api.apollo.io
APOLLO_BASE_URL=
# Per-tenant per-day cap on Apollo calls (counted in Redis). Guards against
# a runaway dev script burning the monthly credit allowance. The dossier
# falls through silently when the cap is hit.
APOLLO_DAILY_CAP_PER_TENANT=50
# Cache TTL for Apollo lookups, in days. Re-running research on the same
# domain inside this window reuses the cached result instead of paying for
# another credit. Bump down if you need fresher data.
APOLLO_CACHE_TTL_DAYS=7

# Phyllo — drives POST /api/knowledge/social-sync. Auth is HTTP Basic.
# Use the staging base URL while connecting accounts; switch to production
# once your client_id/secret are promoted.
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
PHYLLO_BASE_URL=https://api.staging.getphyllo.com

# Retrieval tiebreaker — cosine-distance epsilon for the recency tiebreaker.
# Two chunks within KB_RECENCY_EPSILON rank by newer effective_date first.
KB_RECENCY_EPSILON=0.05
KB_CHUNK_TOKENS=512
KB_CHUNK_OVERLAP=50
KB_RETRIEVAL_K=8
KB_UPLOAD_MAX_MB=25
# Optional — set if using Vertex AI rather than AI Studio
GOOGLE_PROJECT_ID=
GOOGLE_REGION=us-central1

# ---------- Meeting capture (Recall.ai / Skribby) ----------
RECALL_AI_API_KEY=
RECALL_AI_REGION=us-west-2
RECALL_AI_WEBHOOK_SECRET=
# Configure on the Recall.ai dashboard:
#   https://ghoststream.exact-it.net/webhooks/recall
SKRIBBY_API_KEY=
SKRIBBY_WEBHOOK_SECRET=

# ---------- Microsoft Graph (per-user calendar reads) ----------
# One multi-tenant Azure AD application, registered in our Azure tenant. See
# docs/adr/0002-microsoft-graph-direct.md for the design — note §8 dropped the
# original "authenticated Teams bot via admin consent" piece; authenticated
# Teams meeting joining is a one-time operator action on the Recall.ai
# dashboard (configure a Microsoft user account email/password), not handled
# here. The Azure app below is only used for the per-user calendar OAuth flow.
#
# Register at https://portal.azure.com → Azure Active Directory →
# App registrations → "New registration":
#   - Supported account types: "Accounts in any organizational directory"
#     (signInAudience = AzureADMultipleOrgs).
#   - Redirect URI (Web): ${APP_BASE_URL}/api/integrations/microsoft/callback
#   - Delegated permissions only (all user-consent — no admin consent needed):
#     Calendars.ReadWrite, OnlineMeetings.ReadWrite, Contacts.Read, People.Read,
#     User.Read, offline_access, openid, profile.
#   (Calendars.ReadWrite + OnlineMeetings.ReadWrite let GhostStream create
#    Teams meetings + send Outlook invites. Contacts.Read + People.Read feed
#    the attendees autocomplete on the create-meeting form. See ADR-0002 §9.)
# Then mint a client secret and paste it below. MS_CLIENT_SECRET must never
# leave the server.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# `common` lets any Microsoft tenant authenticate against the app. Override
# with a tenant GUID for single-tenant on-prem deployments (sovereign clouds
# also need MS_AUTHORITY_HOST set — see open question §6 in ADR-0002).
MS_TENANT_ID=common
# Optional override — defaults to ${APP_BASE_URL}/api/integrations/microsoft/callback.
# Must match exactly the redirect URI registered on the app.
MS_REDIRECT_URI=

# ---------- Object storage (Cloudflare R2 — S3-compatible) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ghoststream-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

# ---------- Video delivery (Cloudflare Stream) ----------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=

# ---------- Transactional email (SendGrid) ----------
# Sender domain must be authenticated in SendGrid → Settings → Sender
# Authentication (CNAME records). Current authenticated domain: eel-global.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@eel-global.com
SENDGRID_FROM_NAME=GhostStream
SENDGRID_REPLY_TO=

# ---------- Meeting invites (branded GhostStream sender) ----------
# When a rep clicks "Generate Teams meeting" we create the Teams meeting on
# their Outlook calendar (silent — no attendees on the Graph side) and then
# send the .ics invite ourselves via SendGrid. This decouples deliverability
# from the rep's M365 outbound reputation (avoids AADSTS 5.7.708 etc.) and
# keeps the sender consistent across reps. Reply-To is set to the rep's MS
# email so prospects' replies route back to them naturally. See ADR-0002 §10.
MEETINGS_FROM_EMAIL=meetings@eel-global.com
MEETINGS_FROM_NAME=GhostStream Meetings
# Optional override — defaults to the rep's connected Microsoft email.
# Set this to a fixed address if you want all replies funnelled to one inbox.
MEETINGS_REPLY_TO=

# ---------- Slack (Socket Mode) ----------
# App-level token from https://api.slack.com/apps → "Basic Information" →
# "App-Level Tokens", needs the connections:write scope. Used to open the
# WebSocket to Slack's gateway — no inbound port required.
SLACK_APP_TOKEN=

# Bot user OAuth token from "Install App" — starts with xoxb-. Drives the
# Web API calls (post message, reply in thread, etc.).
SLACK_BOT_TOKEN=

# Comma-separated channel ids the bot is allowed to act in. Events from
# any other channel are silently dropped. Leave empty for unrestricted
# (dev only — production should always enumerate).
SLACK_ALLOWED_CHANNELS=

# ---------- gs_coordinator (second Slack app + Anthropic Managed Agents) ----------
# A separate Slack app from the GhostStream Notetaker — distinct bot identity,
# distinct Socket Mode connection, no event-split between the two runners.
SLACK_APP_TOKEN_COORD=
SLACK_BOT_TOKEN_COORD=
# Anthropic Managed Agents — three agents addressable as @SoftwareEng,
# @CodeReviewer, @SysArchitect inside Coordinator threads.
ANTHROPIC_API_KEY=
BUILDER_AGENT_ID=
REVIEWER_AGENT_ID=
ARCHITECT_AGENT_ID=
ENVIRONMENT_ID=
GITHUB_VAULT_ID=

# ---------- Public app URL (used in webhooks / emails / SOW links) ----------
APP_BASE_URL=https://ghoststream.exact-it.net

# ---------- Postgres ----------
POSTGRES_DB=ghoststream
POSTGRES_USER=ghoststream_user
POSTGRES_PASSWORD=change-me

# ---------- Redis ----------
REDIS_PASSWORD=change-me

# ---------- Auth ----------
JWT_SECRET=change-me-32-byte-hex
ADMIN_EMAIL=admin@ghoststream.io
ADMIN_PASSWORD=change-me

# ---------- AI engine (Google Gemini — Vertex AI or AI Studio) ----------
GEMINI_API_KEY=
# Default: gemini-2.5-flash (fast, cheap, 1,024-token cache minimum).
GEMINI_MODEL=gemini-2.5-flash
# Per sprint plan: Pro for video analysis (find Moment-of-Truth), Flash-Lite
# for content drafting (SOW / email / portal copy). Swap to gemini-3.1-* once GA.
GEMINI_ANALYSIS_MODEL=gemini-2.5-pro
GEMINI_CONTENT_MODEL=gemini-2.5-flash
# Knowledge Base — Dynamic Context Layer (pgvector RAG).
# gemini-embedding-2 is a Matryoshka-rep model (GA May 2026). 8,192-token
# input window — accommodates long technical manuals without splitting
# coherent sections. We request 768-dim output to match the vector(768)
# column in api/db/migrations/0001_kb_tables.sql. Supported alternates: 1536,
# 3072 — if you change GEMINI_EMBEDDING_DIM, update the vector(N) column AND
# re-embed every chunk (the HNSW index is dim-locked, and switching embedding
# models also requires a full re-embed since vector spaces are incompatible).
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIM=768

# ---------- Omni-Sync providers (WEB + SOCIAL ingestion) ----------
# Firecrawl — drives POST /api/knowledge/web-sync.
FIRECRAWL_API_KEY=
# Optional override; defaults to https://api.firecrawl.dev/v1
FIRECRAWL_BASE_URL=

# Phyllo — drives POST /api/knowledge/social-sync. Auth is HTTP Basic.
# Use the staging base URL while connecting accounts; switch to production
# once your client_id/secret are promoted.
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
PHYLLO_BASE_URL=https://api.staging.getphyllo.com

# Retrieval tiebreaker — cosine-distance epsilon for the recency tiebreaker.
# Two chunks within KB_RECENCY_EPSILON rank by newer effective_date first.
KB_RECENCY_EPSILON=0.05
KB_CHUNK_TOKENS=512
KB_CHUNK_OVERLAP=50
KB_RETRIEVAL_K=8
KB_UPLOAD_MAX_MB=25
# Optional — set if using Vertex AI rather than AI Studio
GOOGLE_PROJECT_ID=
GOOGLE_REGION=us-central1

# ---------- Meeting capture (Recall.ai / Skribby) ----------
RECALL_AI_API_KEY=
RECALL_AI_REGION=us-west-2
RECALL_AI_WEBHOOK_SECRET=
# Configure on the Recall.ai dashboard:
#   https://ghoststream.exact-it.net/webhooks/recall
SKRIBBY_API_KEY=
SKRIBBY_WEBHOOK_SECRET=

# ---------- Object storage (Cloudflare R2 — S3-compatible) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ghoststream-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

# ---------- Video delivery (Cloudflare Stream) ----------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=

# ---------- Transactional email (SendGrid) ----------
# Sender domain must be authenticated in SendGrid → Settings → Sender
# Authentication (CNAME records). Current authenticated domain: eel-global.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@eel-global.com
SENDGRID_FROM_NAME=GhostStream
SENDGRID_REPLY_TO=
